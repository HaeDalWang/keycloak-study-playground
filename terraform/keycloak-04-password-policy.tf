# =============================================================================
# 시나리오 4: 비밀번호 정책
# =============================================================================
#
# [고객사 요청 표현]
#   "비밀번호를 90일마다 강제로 변경하게 해주세요."
#   "비밀번호는 8자 이상, 대소문자/숫자/특수문자 포함해야 합니다."
#   "이전에 쓴 비밀번호는 재사용 못하게 해주세요."
#   "로그인 5번 실패하면 계정을 잠가주세요."
#
# [작업 전 고객사에게 받아야 할 정보]
#   1. 비밀번호 최소 길이
#   2. 복잡도 요구사항 (대문자/소문자/숫자/특수문자 각 최소 개수)
#   3. 비밀번호 만료 주기 (일 단위, 0=만료 없음)
#   4. 비밀번호 재사용 금지 횟수 (최근 N개 비밀번호 재사용 불가)
#   5. 로그인 실패 잠금 횟수 및 잠금 시간
#
# [기억해야 할 것]
#   - password_policy는 Realm 설정. 모든 사용자에게 일괄 적용.
#   - forceExpiredPasswordChange: 관리자가 만든 계정의 initial_password에도 적용됨.
#     temporary=true로 설정하면 첫 로그인 시 변경 강제 (만료 주기와 별개).
#   - 브루트포스 보호(brute_force_detection)는 별도 설정.
#     잠금된 계정은 Admin Console에서 수동 해제 또는 wait_increment_seconds 후 자동 해제.
#   - LDAP 연동 시: 비밀번호 정책은 Keycloak 로컬 계정에만 적용.
#     LDAP 사용자 비밀번호는 AD/LDAP 서버의 정책을 따름.
#
# [설정 방법]
#   이 파일의 locals를 수정 → keycloak.tf의 keycloak_realm.ezl에 자동 반영
# =============================================================================

locals {
  # ── 비밀번호 복잡도 정책 ──────────────────────────────────
  # 각 정책은 "and"로 연결
  # 고객사 요구사항에 맞게 값 조정
  password_policy = join(" and ", [

    # 최소 길이 (권장: 8자 이상, 금융/공공기관: 10자 이상)
    "length(8)",

    # 대문자 최소 1개 포함
    "upperCase(1)",

    # 소문자 최소 1개 포함
    "lowerCase(1)",

    # 숫자 최소 1개 포함
    "digits(1)",

    # 특수문자 최소 1개 포함
    "specialChars(1)",

    # username과 동일한 비밀번호 금지
    "notUsername",

    # email과 동일한 비밀번호 금지
    "notEmail",

    # 최근 N개 비밀번호 재사용 금지 (0=제한없음)
    "passwordHistory(5)",

    # N일 후 비밀번호 만료 강제 (0=만료없음)
    # 만료 시 다음 로그인에서 변경 화면으로 이동
    "forceExpiredPasswordChange(90)",

    # 비밀번호 해싱 알고리즘 (기본값 유지 권장)
    # pbkdf2-sha256: 현재 Keycloak 기본값
    "hashAlgorithm(pbkdf2-sha256)",

    # 해싱 반복 횟수 (높을수록 보안 강화, 성능 저하)
    # 27500: Keycloak 기본값
    "hashIterations(27500)",
  ])
}
